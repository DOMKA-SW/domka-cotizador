rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════
    // HELPERS — IDENTIDAD
    // ══════════════════════════════════════════════════

    function isAuth()     { return request.auth != null; }
    function uid()        { return request.auth.uid; }

    function userSnap()   {
      return get(/databases/$(database)/documents/usuarios/$(uid()));
    }
    function userRole()   { return isAuth() && userSnap().exists ? userSnap().data.rol   : null; }
    function userActivo() { return isAuth() && userSnap().exists ? userSnap().data.activo == true : false; }

    function isAdmin()     { return isAuth() && userActivo() && userRole() == 'admin'; }
    function isComercial() { return isAuth() && userActivo() && userRole() in ['admin','comercial']; }
    function isTecnico()   { return isAuth() && userActivo() && userRole() in ['admin','comercial','tecnico']; }
    function isCliente()   { return isAuth() && userActivo() && userRole() == 'cliente'; }

    function clienteIdMio() { return userSnap().data.clienteId; }

    // ══════════════════════════════════════════════════
    // HELPERS — VALIDACIÓN DE ESCRITURA
    // ══════════════════════════════════════════════════

    // Solo estos campos pueden cambiar en una transición de estado pública
    function soloEstado() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['estado','fechaRespuesta']);
    }

    // Estado válido para aprobar/rechazar
    function estadoValido(permitidos) {
      return request.resource.data.estado in permitidos;
    }

    // El documento sigue en pendiente (anti double-approve)
    function estaPendiente() {
      return resource.data.estado == 'pendiente';
    }

    // Validar string no vacío con límite de tamaño
    function strOk(v, max) {
      return v is string && v.size() > 0 && v.size() <= max;
    }

    // ══════════════════════════════════════════════════
    // TOKENS PÚBLICOS
    // Token de 64 hex chars. El ID del token ES el token.
    // Protege acceso de lectura Y escritura a docs públicos.
    // ══════════════════════════════════════════════════
    match /public_tokens/{token} {
      // Lectura permitida — token de 64 chars es inaccesible por fuerza bruta
      allow get:  if true;
      allow list: if isAdmin();

      // Solo usuarios internos crean tokens
      allow create: if isComercial()
        && request.resource.data.keys().hasAll(['docId','tipo','expiraEn','activo','accesos'])
        && request.resource.data.activo == true
        && request.resource.data.accesos == 0
        && request.resource.data.tipo in ['cotizaciones','cuentas','documentos']
        && strOk(request.resource.data.docId, 30);

      // Público puede incrementar accesos (lectura registrada) o desactivar (acción)
      // Comercial puede desactivar/regenerar
      allow update: if isComercial()
        || (!isAuth()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['accesos','ultimoAcceso'])
            && request.resource.data.accesos == resource.data.accesos + 1);

      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════
    // USUARIOS
    // ══════════════════════════════════════════════════
    match /usuarios/{docUid} {
      allow get:  if isAuth() && (uid() == docUid || isAdmin());
      allow list: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.keys().hasAll(['email','nombre','rol','activo'])
        && request.resource.data.rol in ['admin','comercial','tecnico','cliente']
        && request.resource.data.activo is bool
        && strOk(request.resource.data.email, 200)
        && strOk(request.resource.data.nombre, 100);

      allow update: if isAdmin()
        || (isAuth() && uid() == docUid
            && !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['rol','activo','clienteId']));

      allow delete: if false;
    }

    // ══════════════════════════════════════════════════
    // CLIENTES
    // ══════════════════════════════════════════════════
    match /clientes/{docId} {
      allow get:  if isTecnico();
      allow list: if isComercial();

      allow create: if isComercial()
        && request.resource.data.keys().hasAll(['nombre'])
        && strOk(request.resource.data.nombre, 200);

      allow update: if isComercial();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════
    // COTIZACIONES
    // Lectura pública: solo vía token (get docId → leer doc)
    // allow get: if true es necesario para el flujo público;
    // la protección real está en el token (64 chars inaccesible).
    // ══════════════════════════════════════════════════
    match /cotizaciones/{docId} {
      allow get:  if isComercial()
        || (isCliente() && resource.data.clienteId == clienteIdMio())
        || true; // links públicos — protegidos por token inaccesible + list bloqueado

      allow list: if isComercial()
        || (isCliente() && resource.data.clienteId == clienteIdMio());

      allow create: if isComercial()
        && request.resource.data.keys().hasAll(['clienteId','nombreCliente','total','estado'])
        && request.resource.data.estado == 'pendiente'
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && strOk(request.resource.data.clienteId, 30)
        && strOk(request.resource.data.nombreCliente, 200);

      allow update: if isComercial()
        // Cliente logueado — solo SU cotización, solo estado, solo si está pendiente
        || (isCliente()
            && resource.data.clienteId == clienteIdMio()
            && estaPendiente()
            && soloEstado()
            && estadoValido(['aprobada','rechazada']))
        // Visitante público — solo estado + anti-double-approve
        || (!isAuth()
            && estaPendiente()
            && soloEstado()
            && estadoValido(['aprobada','rechazada']));

      allow delete: if false;
    }

    // ══════════════════════════════════════════════════
    // CUENTAS DE COBRO
    // ══════════════════════════════════════════════════
    match /cuentas/{docId} {
      allow get:  if isComercial()
        || (isCliente() && resource.data.clienteId == clienteIdMio())
        || true;

      allow list: if isComercial()
        || (isCliente() && resource.data.clienteId == clienteIdMio());

      allow create: if isComercial()
        && request.resource.data.keys().hasAll(['clienteId','nombreCliente','total','estado'])
        && request.resource.data.estado == 'pendiente'
        && request.resource.data.total is number
        && request.resource.data.total >= 0;

      allow update: if isComercial()
        || (isCliente()
            && resource.data.clienteId == clienteIdMio()
            && estaPendiente()
            && soloEstado()
            && estadoValido(['aprobada','rechazada']))
        || (!isAuth()
            && estaPendiente()
            && soloEstado()
            && estadoValido(['aprobada','rechazada']));

      allow delete: if false;
    }

    // ══════════════════════════════════════════════════
    // PROYECTOS — No acceso público
    // ══════════════════════════════════════════════════
    match /proyectos/{docId} {
      allow get: if isComercial()
        || (isTecnico() && resource.data.tecnicoId == uid())
        || (isCliente() && resource.data.clienteId == clienteIdMio());

      allow list: if isComercial()
        || (isTecnico() && resource.data.tecnicoId == uid())
        || (isCliente() && resource.data.clienteId == clienteIdMio());

      allow create: if isComercial()
        && request.resource.data.keys().hasAll(['clienteId','nombreCliente','estado','evidencias'])
        && request.resource.data.estado == 'pendiente'
        && request.resource.data.evidencias is list;

      allow update: if isComercial()
        || (isAuth() && userRole() == 'tecnico'
            && resource.data.tecnicoId == uid()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['estado','evidencias','updatedAt']));

      allow delete: if false;
    }

    // ══════════════════════════════════════════════════
    // DOCUMENTOS
    // ══════════════════════════════════════════════════
    match /documentos/{docId} {
      allow get:  if isComercial()
        || (isCliente() && resource.data.clienteId == clienteIdMio())
        || true;

      allow list: if isComercial()
        || (isCliente() && resource.data.clienteId == clienteIdMio());

      allow create: if isComercial()
        && request.resource.data.keys().hasAll(['clienteId','nombreCliente','tipo','estado'])
        && request.resource.data.estado == 'pendiente'
        && strOk(request.resource.data.tipo, 100);

      allow update: if isComercial()
        || (isCliente()
            && resource.data.clienteId == clienteIdMio()
            && estaPendiente()
            && soloEstado()
            && estadoValido(['aprobado','rechazado']))
        || (!isAuth()
            && estaPendiente()
            && soloEstado()
            && estadoValido(['aprobado','rechazado']));

      allow delete: if false;
    }

    // ══════════════════════════════════════════════════
    // LOGS — escritura pública limitada, lectura admin
    // ══════════════════════════════════════════════════
    match /logs/{docId} {
      allow read: if isAdmin();
      allow create: if
        request.resource.data.keys().hasAll(['tipo','accion','timestamp'])
        && request.resource.data.tipo in ['cotizacion','cuenta','documento','proyecto']
        && request.resource.data.accion in [
          'vista','aprobada','rechazada','aprobado','rechazado',
          'recibido_confirmado','proyecto_creado','evidencia_subida'
        ]
        // Limitar tamaño para anti-spam
        && request.resource.data.keys().size() <= 12
        && !request.resource.data.keys().hasAny(['__proto__','constructor','prototype']);
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════
    // MÓDULO FINANCIERO — Solo Admin
    // ══════════════════════════════════════════════════
    match /movimientos/{docId}    { allow read, write: if isAdmin(); }
    match /cuentasBancarias/{docId} { allow read, write: if isAdmin(); }

    // ══════════════════════════════════════════════════
    // CONTADORES
    // ══════════════════════════════════════════════════
    match /contadores/{docId} {
      allow get:    if isAuth();
      allow list:   if isAdmin();
      allow create: if isComercial();
      allow update: if isComercial()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ultimo'])
        && request.resource.data.ultimo is number;
      allow delete: if false;
    }

  }
}
